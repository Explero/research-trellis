{
  "name": "research-trellis-core",
  "version": "0.6.0-beta.31",
  "description": "Research Trellis core SDK for channels, tasks, memory, and auditable research records",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./channel": {
      "types": "./dist/channel/index.d.ts",
      "import": "./dist/channel/index.js",
      "default": "./dist/channel/index.js"
    },
    "./mem": {
      "types": "./dist/mem/index.d.ts",
      "import": "./dist/mem/index.js",
      "default": "./dist/mem/index.js"
    },
    "./task": {
      "types": "./dist/task/index.d.ts",
      "import": "./dist/task/index.js",
      "default": "./dist/task/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "COPYRIGHT"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm run clean && tsc",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "typecheck": "tsc --noEmit",
    "sync-package-docs": "node -e \"const fs=require('node:fs'); fs.copyFileSync('../../README.md','README.md'); fs.copyFileSync('../../LICENSE','LICENSE'); fs.copyFileSync('../../COPYRIGHT','COPYRIGHT');\"",
    "prepack": "pnpm run build && pnpm run sync-package-docs",
    "prepublishOnly": "pnpm run build && pnpm run sync-package-docs"
  },
  "keywords": [
    "trellis",
    "channel",
    "sdk",
    "agent",
    "events"
  ],
  "author": "Explero",
  "contributors": [
    "Mindfold LLC",
    "Trellis contributors"
  ],
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.17.10",
    "eslint": "^9.18.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Explero/research-trellis.git"
  }
}
